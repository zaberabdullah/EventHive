# MongoDB connection string (Atlas or local) — include a database name, e.g. /eventhive
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/eventhive

# Secret used to sign JWTs — use a long random string in production
JWT_SECRET=replace-this-with-a-long-random-secret

# Cookie name for the auth token (optional override)
AUTH_COOKIE_NAME=eventhive_token
